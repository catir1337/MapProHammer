<Window x:Class="MapProHammer.Views.View3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Просмотр — MapPro Hammer"
        Width="1050" Height="720"
        Background="#1e1e1e"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background"  Value="#3c3c3c"/>
            <Setter Property="Foreground"  Value="#cccccc"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="8,4"/>
            <Setter Property="Margin"      Value="2"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"        Value="#cccccc"/>
            <Setter Property="Margin"            Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cccccc"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ═══ Toolbar ═══ -->
        <ToolBar DockPanel.Dock="Top" Background="#2d2d2d" Foreground="#cccccc">
            <Button x:Name="BtnFit" Content="⊡ Fit" Click="BtnFit_Click"
                    ToolTip="Сбросить камеру к центру сцены (F)"/>
            <Separator/>
            <CheckBox x:Name="ChkGrid" Content="Сетка"   IsChecked="True"
                      Checked="Rebuild_Changed" Unchecked="Rebuild_Changed"/>
            <CheckBox x:Name="ChkAxes" Content="Оси XYZ" IsChecked="True"
                      Checked="Rebuild_Changed" Unchecked="Rebuild_Changed"/>
            <Separator/>
            <TextBlock x:Name="TxtCount" VerticalAlignment="Center" Margin="4,0"/>
        </ToolBar>

        <!-- ═══ Status bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom" Background="#2d2d2d">
            <TextBlock Text="ЛКМ+тяни — орбита  |  ПКМ+тяни — пан  |  Колесо — зум  |  ЛКМ клик — выбор объекта"
                       Foreground="#555" FontSize="11"/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtSelInfo" Foreground="#9ab" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Main: Viewport3D + Legend overlay ═══ -->
        <Grid>
            <Viewport3D x:Name="Viewport"
                        ClipToBounds="True"
                        Focusable="True"
                        KeyDown="Vp_KeyDown"
                        MouseDown="Vp_MouseDown"
                        MouseMove="Vp_MouseMove"
                        MouseUp="Vp_MouseUp"
                        MouseWheel="Vp_MouseWheel">
                <Viewport3D.Camera>
                    <PerspectiveCamera x:Name="Camera"
                                       FieldOfView="55"
                                       NearPlaneDistance="0.1"
                                       FarPlaneDistance="2000000"/>
                </Viewport3D.Camera>

                <!-- Lighting -->
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <Model3DGroup>
                            <AmbientLight     Color="#505050"/>
                            <DirectionalLight Color="#bbbbbb" Direction="-1,-2,-1.5"/>
                            <DirectionalLight Color="#223355" Direction="1,1,0.5"/>
                        </Model3DGroup>
                    </ModelVisual3D.Content>
                </ModelVisual3D>

                <ModelVisual3D x:Name="GridVisual"/>
                <ModelVisual3D x:Name="ObjectsVisual"/>
                <ModelVisual3D x:Name="AxesVisual"/>
                <ModelVisual3D x:Name="SelectionVisual"/>
            </Viewport3D>

            <!-- Legend (top-right, non-interactive) -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="#c21a1a1a" BorderBrush="#3c3c3c" BorderThickness="1"
                    CornerRadius="4" Margin="10" Padding="10,8"
                    IsHitTestVisible="False">
                <StackPanel>
                    <TextBlock Text="ЛЕГЕНДА" Foreground="#555" FontSize="9"
                               FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Rectangle Width="10" Height="10" Fill="#5a5a6e" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Generic"    Foreground="#888" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Rectangle Width="10" Height="10" Fill="#326ec8" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SpawnCar"   Foreground="#888" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Rectangle Width="10" Height="10" Fill="#28aa3c" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SpawnHuman" Foreground="#888" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Rectangle Width="10" Height="10" Fill="#c88c1e" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Wire"        Foreground="#888" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Rectangle Width="10" Height="10" Fill="#a028a0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Decal"       Foreground="#888" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Rectangle Width="10" Height="10" Fill="Yellow" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Выбран"     Foreground="#ffff80" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
