<Window x:Class="MapProHammer.Views.NewTypeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый тип объекта (меш)"
        Width="460" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e1e1e">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#3c3c3c"/>
            <Setter Property="Foreground"  Value="#ccc"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="4,3"/>
            <Setter Property="Margin"      Value="0,2,0,8"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="Padding"    Value="0,4,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"  Value="#3c3c3c"/>
            <Setter Property="Foreground"  Value="#ccc"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="14,5"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ccc"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Кнопки OK/Отмена -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Отмена" Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnOK" Content="Зарегистрировать"
                    Click="BtnOK_Click"
                    Background="#094771" Foreground="White" BorderBrush="#1177bb"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Путь к мешу (ObjPath)" Foreground="#888" FontSize="11"/>
            <TextBlock Text="Например: Props/Decor/MyStatue.prefab" Foreground="#555" FontSize="10" Margin="0,0,0,2"/>
            <TextBox x:Name="TbObjPath" />

            <TextBlock Text="GUID ассета (необязательно)" Foreground="#888" FontSize="11"/>
            <TextBlock Text="Оставь пустым, если не знаешь" Foreground="#555" FontSize="10" Margin="0,0,0,2"/>
            <TextBox x:Name="TbGuid" />
        </StackPanel>

    </DockPanel>
</Window>
