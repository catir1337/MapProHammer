<Window x:Class="MapProHammer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MapPro Hammer"
        Width="1280" Height="800"
        Background="#1e1e1e">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel"    Color="#252526"/>
        <SolidColorBrush x:Key="BgToolbar"  Color="#2d2d2d"/>
        <SolidColorBrush x:Key="BgViewport" Color="#1a1a1a"/>
        <SolidColorBrush x:Key="FgText"     Color="#cccccc"/>
        <SolidColorBrush x:Key="Accent"     Color="#007acc"/>

        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="#3c3c3c"/>
            <Setter Property="Foreground"  Value="#cccccc"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="8,4"/>
            <Setter Property="Margin"      Value="2"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#3c3c3c"/>
            <Setter Property="Foreground"  Value="#cccccc"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="2"/>
            <Setter Property="Margin"      Value="0,2"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="Padding"    Value="0,2,4,2"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background"  Value="#252526"/>
            <Setter Property="Foreground"  Value="#cccccc"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a2d2e"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="#3c3c3c"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cccccc"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ═══ Toolbar ═══ -->
        <ToolBar DockPanel.Dock="Top" Background="{StaticResource BgToolbar}"
                 Foreground="#cccccc">
            <Button x:Name="BtnOpen"   Click="BtnOpen_Click"   Content="📂 Открыть"/>
            <Button x:Name="BtnSave"   Click="BtnSave_Click"   Content="💾 Сохранить" IsEnabled="False"/>
            <Button x:Name="BtnSaveAs" Click="BtnSaveAs_Click" Content="💾 Сохранить как…" IsEnabled="False"/>
            <Separator/>
            <Button x:Name="BtnDelete" Click="BtnDelete_Click" Content="🗑 Удалить"  IsEnabled="False"/>
            <Separator/>
            <Button x:Name="BtnInfo"   Click="BtnInfo_Click"   Content="ℹ Info"/>
            <Button x:Name="BtnAddType"    Click="BtnAddType_Click"    Content="📦 Новый тип"    IsEnabled="False" ToolTip="Зарегистрировать новый тип меш-объекта в карте"/>
            <Button x:Name="BtnDeleteType" Click="BtnDeleteType_Click" Content="🗑 Удалить тип" IsEnabled="False" ToolTip="Удалить тип объекта из карты"/>
            <Button x:Name="BtnAdd"    Click="BtnAdd_Click"    Content="➕ Добавить"/>
            <Button x:Name="BtnEdit"   Click="BtnEdit_Click"   Content="✏ Изменить" IsEnabled="False"/>
            <Separator/>
            <!-- ★ Новая кнопка 3D ★ -->
            <Button x:Name="BtnView3D" Click="BtnView3D_Click" Content="🗺 3D Вид"
                    IsEnabled="False"
                    ToolTip="Открыть 3D-просмотрщик объектов карты"/>
            <Separator/>
            <TextBlock VerticalAlignment="Center" Margin="4,0" x:Name="TxtStatus" Text="Откройте Map.bytes…"/>
        </ToolBar>

        <!-- ═══ Status bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource BgToolbar}">
            <StatusBarItem>
                <TextBlock x:Name="TxtInfo" Text="" Foreground="#aaa"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtCoords" Text="" Foreground="#888"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Main area ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="260" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: object list -->
            <DockPanel Grid.Column="0" Background="{StaticResource BgPanel}">
                <TextBlock DockPanel.Dock="Top" Text="ОБЪЕКТЫ" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="8,6,0,4"/>
                <TextBox  DockPanel.Dock="Top"  x:Name="TxtSearch"
                          TextChanged="TxtSearch_TextChanged"
                          Margin="4,0,4,4" Background="#3c3c3c"
                          Foreground="#ccc" BorderBrush="#555"
                          Text="" Tag="Поиск…">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background"  Value="#3c3c3c"/>
                            <Setter Property="Foreground"  Value="#ccc"/>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <ListBox  x:Name="ListObjects"
                          SelectionChanged="ListObjects_SelectionChanged"
                          BorderThickness="0"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.IsDeferredScrollingEnabled="True">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="🗑 Удалить" Click="CtxDelete_Click"/>
                            <MenuItem Header="📍 Показать на карте" Click="CtxFocus_Click"/>
                            <Separator/>
                            <MenuItem Header="📋 Копировать имя" Click="CtxCopyName_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

            <!-- Center: 2D viewport -->
            <Border Grid.Column="2" Background="{StaticResource BgViewport}"
                    ClipToBounds="True"
                    x:Name="ViewportBorder">
                <Canvas x:Name="ViewportCanvas"
                        Focusable="True"
                        MouseWheel="Viewport_MouseWheel"
                        MouseDown="Viewport_MouseDown"
                        MouseMove="Viewport_MouseMove"
                        MouseUp="Viewport_MouseUp"
                        KeyDown="Viewport_KeyDown">
                </Canvas>
            </Border>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"/>

            <!-- Right panel: properties -->
            <DockPanel Grid.Column="4" Background="{StaticResource BgPanel}">
                <TextBlock DockPanel.Dock="Top" Text="СВОЙСТВА" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="8,6,0,6"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PropsPanel" Margin="8,0">

                        <TextBlock Text="Позиция" Foreground="#888" FontSize="11" Margin="0,4,0,2"/>
                        <Grid x:Name="GridPos">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X" Foreground="#e07070"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TbPosX" TextChanged="Transform_Changed"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y" Foreground="#70e070"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbPosY" TextChanged="Transform_Changed"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Z" Foreground="#7070e0"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TbPosZ" TextChanged="Transform_Changed"/>
                        </Grid>

                        <TextBlock Text="Поворот (Euler)" Foreground="#888" FontSize="11" Margin="0,8,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X" Foreground="#e07070"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TbRotX" TextChanged="Transform_Changed"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y" Foreground="#70e070"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbRotY" TextChanged="Transform_Changed"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Z" Foreground="#7070e0"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TbRotZ" TextChanged="Transform_Changed"/>
                        </Grid>

                        <TextBlock Text="Масштаб" Foreground="#888" FontSize="11" Margin="0,8,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X" Foreground="#e07070"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TbScaleX" TextChanged="Transform_Changed"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y" Foreground="#70e070"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbScaleY" TextChanged="Transform_Changed"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Z" Foreground="#7070e0"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TbScaleZ" TextChanged="Transform_Changed"/>
                        </Grid>

                        <Separator Margin="0,10" Background="#444"/>

                        <TextBlock x:Name="TxtObjType" Text="" Foreground="#aaa" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <StackPanel x:Name="ExtraProps"/>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
